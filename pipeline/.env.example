# =====================================================
# .env.example — API 키 환경변수 템플릿
# 이 파일을 복사하여 .env 로 이름을 변경하고
# 실제 API 키를 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
# =====================================================

# ─────────────────────────────────────────────
# 1. 네이버 개발자 센터 API 키
#    발급 방법:
#    1) https://developers.naver.com 접속 → 로그인
#    2) [Application 등록] → 서비스 URL: http://localhost
#    3) 사용 API: [데이터랩(쇼핑)] 선택
#    4) 등록 후 Client ID / Client Secret 복사
# ─────────────────────────────────────────────
NAVER_CLIENT_ID=여기에_네이버_Client_ID_입력
NAVER_CLIENT_SECRET=여기에_네이버_Client_Secret_입력

# ─────────────────────────────────────────────
# 2. Google Gemini API 키
#    발급 방법:
#    1) https://aistudio.google.com/app/apikey 접속
#    2) [Create API key] 클릭 → 키 복사
#    ※ 무료 티어: 분당 15회 / 일 1,500회 요청 가능
# ─────────────────────────────────────────────
GEMINI_API_KEY=여기에_Gemini_API_키_입력
